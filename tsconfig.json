{
    "compilerOptions": {
      "jsx": "react",
      "target": "ES2020",
      "module": "ESNext",
      "declaration": true,
      "declarationDir": "dist",
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "node",
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }
  